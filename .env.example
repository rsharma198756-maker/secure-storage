# Copy this file to `.env` and fill your values.
# Docker Compose automatically loads `.env` in this folder.

# Security: never return OTP in login API responses outside local debugging.
RETURN_OTP_IN_RESPONSE=false

# Gmail SMTP (recommended: port 587 + STARTTLS)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true

# Use your Gmail address and a Google App Password (not your normal Gmail password).
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-16-char-app-password

# Usually same as SMTP_USER for Gmail.
SMTP_FROM=your-account@gmail.com

# Gateway <-> Storage service authentication (must match on both services in deployment)
SERVICE_JWT_SECRET=replace-with-a-long-random-secret
SERVICE_JWT_ISSUER=secure-gateway
SERVICE_JWT_AUDIENCE=secure-storage
SERVICE_JWT_TTL_SECONDS=30
